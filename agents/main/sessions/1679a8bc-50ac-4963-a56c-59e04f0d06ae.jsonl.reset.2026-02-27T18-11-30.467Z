coding-agent\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 discord\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 eightctl\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 gemini\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 gh-issues\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 gifgrep\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 github\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 gog\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 goplaces\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 healthcheck\ndrwxr-xr-x@  4 lvze  staff   128  2 28 00:25 himalaya\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 imsg\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 mcporter\ndrwxr-xr-x@  5 lvze  staff   160  2 28 00:25 model-usage\ndrwxr-xr-x@  4 lvze  staff   128  2 28 00:25 nano-banana-pro\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 nano-pdf\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 notion\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 obsidian\ndrwxr-xr-x@  4 lvze  staff   128  2 28 00:25 openai-image-gen\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 openai-whisper\ndrwxr-xr-x@  4 lvze  staff   128  2 28 00:25 openai-whisper-api\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 openhue\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 oracle\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 ordercli\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 peekaboo\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 sag\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 session-logs\ndrwxr-xr-x@  4 lvze  staff   128  2 28 00:25 sherpa-onnx-tts\ndrwxr-xr-x@  5 lvze  staff   160  2 28 00:25 skill-creator\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 slack\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 songsee\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 sonoscli\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 spotify-player\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 summarize\ndrwxr-xr-x@  3 lvze  staff    96  2 28 00:25 things-mac\ndrwxr-xr-x@  4 lvze  staff   128  2 28 00:25 tmux\ndrwxr-xr-x@  3 lvze  staff    9