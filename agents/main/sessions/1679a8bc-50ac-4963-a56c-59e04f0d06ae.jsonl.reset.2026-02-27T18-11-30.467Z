eAllowlist(config?.skills?.allowBundled);\n}\n\nexport function isBundledSkillAllowed(entry: SkillEntry, allowlist?: string[]): boolean {\n  if (!allowlist || allowlist.length === 0) {\n\n[43 more lines in file. Use offset=61 to continue.]"}],"isError":false,"timestamp":1772215035337}}
