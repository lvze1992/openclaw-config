s.argv) < 2:\n        print(\"Usage:\")\n        print(f\"  {sys.argv[0]} 'Title' 'output.pptx'\")\n        print(f\"  {sys.argv[0]} --json slides.json output.pptx\")\n        sys.exit(1)\n    \n    if sys.argv[1] == '--json':\n        # JSON input mode\n        with open(sys.argv[2], 'r') as f:\n            data = json.load(f)\n        create_presentation(\n            title=data.get('title', 'Presentation'),\n            subtitle=data.get('subtitle', ''),\n            slides_data=data.get('slides', []),\n            output_path=sys.argv[3] if len(sys.argv) > 3 else 'output.pptx'\n        )\n    else:\n        # Simple mode\n        title = sys.argv[1]\n        output = sys.argv[2] if len(sys.argv) > 2 else 'output.pptx'\n        create_presentation(title, output_path=output)\n\n\nif __name__ == '__main__':\n    main()\nEOF"}}],"api":"openai-completions","provider":"moonshot","model":"kimi-k2.5","usage":{"input":369,"output":701,"cacheRead":23552,"cacheWrite":0,"totalTokens":24622,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772214176502}}
